<div>
    {{#each hits}}
        <div class="row mb-3">
            <div class="col-md-3">
                <img
                    src="{{LocalPosterPath}}"
                    class="img-fluid w-100 p-1 border"
                    alt="{{LinkTitle}}"
                />
            </div>
            <div class="col-md-9">
                <div class="card">
                    <div class="card-header">
                        <h6>
                            {{{LinkTitle}}}{{#if AverageScore}}
                                <span class="small">(FCG Rating
                                    {{AverageScore}})</span>
                            {{/if}}
                        </h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm card-table">
                            {{#if Genres}}
                                <tr>
                                    <th>Genres</th>
                                    <td>{{Genres}}</td>
                                </tr>
                            {{/if}}
                            {{#if Language}}
                                <tr>
                                    <th>Language</th>
                                    <td>{{{Language}}}</td>
                                </tr>
                            {{/if}}
                            {{#if Director}}
                                <tr>
                                    <th>Director</th>
                                    <td>{{{Director}}}</td>
                                </tr>
                            {{/if}}
                            {{#if Cast}}
                                <tr>
                                    <th>Cast</th>
                                    <td>{{{Cast}}}</td>
                                </tr>
                            {{/if}}
                            {{#if Reviewers}}
                                <tr>
                                    <th>Reviewers</th>
                                    <td>{{{Reviewers}}}</td>
                                </tr>
                            {{/if}}
                        </table>
                        {{#if Overview}}
                            <p class="mt-3">{{{Overview}}}</p>
                        {{/if}}
                        <a href="{{URLPath}}" target="_blank" rel="noopener">
                            Read all reviews of
                            {{{LinkTitle}}}
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <hr />
    {{/each}}
</div>
# Copy this to .env.local and fill in values from your AWS Console

# Cognito
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=auth.fcgreviews.com

# Auth redirect URLs
VITE_REDIRECT_SIGN_IN=http://localhost:5173
VITE_REDIRECT_SIGN_OUT=http://localhost:5173

# API Gateway base URL (Lambda)
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod

# FCG site base URL (for reading Hugo JSON)
VITE_SITE_BASE_URL=https://www.fcgreviews.com

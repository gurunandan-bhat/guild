{{- $reviews := slice }}
{{- $linkTitle := (index .Pages 0).LinkTitle }}
{{- $reviewers := slice }}
{{- range .Pages }}
    {{- $pageMap := (jsonify . ) | transform.Unmarshal }}
    {{- $critics := slice }}
    {{- $media := "" }}
    {{- $source := "" }}
    {{- $subtitle := "" }}
    {{- $img := "" }}
    {{- $score := 0 }}
    {{- with index .Params "critics" }}
        {{- $critics = . }}
        {{- $reviewers = append $reviewers $critics }}
    {{- end }}
    {{- with index .Params "source" }}
        {{- $source = . }}
    {{- end }}
    {{- with index .Params "media" }}
        {{- $media = . }}
    {{- end }}
    {{- with index .Params "subtitle" }}
        {{- $subtitle = . }}
    {{- end }}
    {{- with index .Params "img" }}
        {{- $img = . }}
    {{- end }}
    {{- with index .Params "score" }}
        {{- $score = . }}
    {{- end }}
    {{- $pageMap = merge $pageMap (dict
        "ReviewPath" (urlize .Path)
        "Params" .Params
        "Critic" $critics
        "Media" $media
        "Source" $source
        "SubTitle" $subtitle
        "Summary" .Summary
        "Content" .RawContent
        "Image" $img
        "Score" $score)
    }}
    {{- $reviews = append $pageMap $reviews }}
{{- end }}
{{- $metadata := partial "taxonomy/mreviews/metadata-raw.html" $linkTitle }}
{{- $metadata = merge $metadata (dict "Reviewers" (delimit $reviewers ", ")) }}
{{- $result := dict "Metadata" $metadata }}
{{- $result = merge $result (dict "Reviews" $reviews) }}
{{- $result | jsonify (dict "prefix" "" "indent" "\t") }}

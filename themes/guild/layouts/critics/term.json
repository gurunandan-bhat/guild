{{- $reviews := dict }}
{{- range .Pages }}
    {{- $review := (jsonify . | transform.Unmarshal) }}
    {{- $review = merge $review (dict "Publication" (index .Params "publication")) }}
    {{- $hash := md5 .LinkTitle }}
    {{- $reviews = merge $reviews (dict $hash $review) }}
{{- end }}
{{- $reviews | jsonify (dict "prefix" "" "indent" "\t") }}
